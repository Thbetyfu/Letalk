# === LETALK BACKEND CONFIG ===

# MongoDB
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/

# JWT
JWT_SECRET=ganti-dengan-string-random-panjang-minimal-32-karakter

# Django
DJANGO_SECRET_KEY=ganti-dengan-django-secret-key-yang-aman

# Redis (Upstash atau lokal)
REDIS_URL=rediss://default:password@host:6379

# Email (untuk OTP reset PIN)
LETALK_EMAIL=your_email@gmail.com
LETALK_EMAIL_PASSWORD=your_app_password

# Google OAuth
GOOGLE_CLIENT_ID=your_google_oauth_client_id

# R2 Storage (Cloudflare)
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=your_r2_bucket_name
R2_ENDPOINT=https://your_r2_endpoint
R2_REGION=auto

# AI Services
GOOGLE_API_KEY=your_gemini_api_key
EMOTION_API_URL=http://localhost:8001
TOXICITY_API_URL=http://localhost:8002
